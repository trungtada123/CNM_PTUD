# postgresql
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_PORT=5432
DB_HOST=postgres

# pgAdmin configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Mage configuration
MAGE_PROJECT_NAME=mage-src
MAGE_PORT=6789
MAGE_ADMIN_EMAIL=admin@admin.com
MAGE_ADMIN_PASSWORD=admin
MAGE_ADMIN_USERNAME=admin

# Redis configuration
REDIS_PORT=6379
REDIS_HOST=redis

# MinIO configuration
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://minio:${MINIO_API_PORT}
MINIO_FEATURES_BUCKET_NAME=features-store
MINIO_MODELS_BUCKET_NAME=mlflow-artifacts

# MLflow configuration
MLFLOW_PORT=5000
# MLFLOW_HOST=mlflow
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://${MINIO_MODELS_BUCKET_NAME}
